      </div>

      <!-- STEP 5: POA Sign -->
      <div class="form-step" id="step5">
        <h3>Power of Attorney</h3>
        <p>Please read and sign the Power of Attorney authorizing us to act on your behalf.</p>
        <div class="poa-box" id="poaText">
          <strong>POWER OF ATTORNEY</strong><br><br>
          I, the undersigned ("the Principal"), hereby appoint ClearPath Financial (Pty) Ltd, Registration Number [XXXXXXX], ("the Agent"), to act as my lawful attorney and agent in my name, place and stead, to do the following on my behalf:<br><br>
          1. To communicate with, correspond with, and negotiate with any and all subscription service providers, financial institutions, insurance companies, telecommunications companies, and any other service providers with whom I have current agreements or contracts;<br><br>
          2. To request, obtain, and review any statements, contracts, billing information, and related documents from such service providers;<br><br>
          3. To cancel, renegotiate, modify, or optimize any subscription, contract, insurance policy, banking service, or telecommunications agreement on my behalf;<br><br>
          4. To submit applications for debt consolidation loans on my behalf to registered financial institutions and credit providers;<br><br>
          5. To obtain my credit report from registered credit bureaux for purposes of providing the above services;<br><br>
          6. To sign any documents reasonably necessary to give effect to the above on my behalf;<br><br>
          This Power of Attorney shall remain in force until the completion of the agreed services or until revoked by me in writing with 5 (five) business days notice.<br><br>
          I confirm that I am over 18 years of age, am legally competent to enter into this agreement, and have read and understood the terms set out herein.<br><br>
          Signed at _____________ on this _____ day of _____________ 20___
        </div>
        <div style="margin-bottom:16px">
          <label style="font-size:13px;font-weight:600;color:var(--text-muted);letter-spacing:.5px;text-transform:uppercase;display:block;margin-bottom:10px">Draw Your Signature Below</label>
          <div class="sign-canvas-wrap">
            <canvas id="sigCanvas" height="140" style="background:rgba(255,255,255,0.04)"></canvas>
          </div>
          <div class="sign-actions">
            <button class="btn btn-outline" onclick="clearSig()" style="font-size:13px;padding:8px 16px"><i class="fas fa-redo" style="margin-right:6px"></i>Clear</button>
            <a href="#" class="btn btn-outline" onclick="downloadPOA()" style="font-size:13px;padding:8px 16px"><i class="fas fa-download" style="margin-right:6px"></i>Download POA PDF</a>
          </div>
        </div>
        <label style="display:flex;gap:10px;align-items:flex-start;cursor:pointer;font-size:13px;color:var(--text-muted)">
          <input type="checkbox" id="f_poa_agree" style="width:16px;height:16px;margin-top:2px;accent-color:var(--gold)">
          <span>I have read, understood, and agree to the Power of Attorney above. My electronic signature constitutes a legally binding signature under the Electronic Communications and Transactions Act (ECT Act) of South Africa.</span>
        </label>
      </div>

      <!-- STEP 6: Review & Submit -->
      <div class="form-step" id="step6">
        <h3>Review & Submit</h3>
        <p>Please review your details before submitting your application.</p>
        <div id="reviewSummary" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:20px;margin-bottom:20px;font-size:14px;line-height:2;color:var(--text-muted)"></div>
        <div style="background:rgba(201,168,76,0.06);border:1px solid var(--border);border-radius:10px;padding:16px;margin-bottom:20px">
          <p style="font-size:13px;color:var(--text-muted);line-height:1.7">
            <i class="fas fa-shield-alt" style="color:var(--gold);margin-right:8px"></i>
            By submitting this application, you confirm that all information provided is accurate and complete. Your application will be reviewed within 24 hours and you will receive a confirmation email and WhatsApp message.
          </p>
        </div>
      </div>

      <!-- SUCCESS SCREEN -->
      <div class="success-screen" id="successScreen">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h2>Application Submitted!</h2>
        <p>Thank you! We've received your application and will review it within 24 hours. Check your email and WhatsApp for confirmation.</p>
        <div class="ref-badge" id="refNumber">REF: CP-000000</div>
        <div style="margin-top:24px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <a href="client-portal.html" class="btn btn-gold">Access Client Portal</a>
          <button class="btn btn-outline" onclick="closeApply()">Close</button>
        </div>
      </div>

      <div class="form-nav" id="formNav">
        <span class="step-label" id="stepLabel">Step 1 of 6</span>
        <div style="display:flex;gap:10px">
          <button class="btn btn-outline" id="prevBtn" onclick="prevStep()" style="display:none">← Back</button>
          <button class="btn btn-gold" id="nextBtn" onclick="nextStep()">Continue →</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CHAT WIDGET -->
<div class="chat-float">
  <div class="chat-window" id="chatWindow">
    <div class="chat-header">
      <div class="chat-avatar"><i class="fas fa-headset"></i></div>
      <div>
        <h4>ClearPath Support</h4>
        <p><i class="fas fa-circle" style="font-size:8px"></i> Online now</p>
      </div>
      <button onclick="toggleChat()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;margin-left:auto;font-size:16px"><i class="fas fa-times"></i></button>
    </div>
    <div class="chat-msgs" id="chatMsgs">
      <div class="chat-msg agent">👋 Hello! Welcome to ClearPath Financial. How can I help you today?</div>
    </div>
    <div class="chat-input">
      <input type="text" id="chatInput" placeholder="Type a message..." onkeypress="if(event.key==='Enter')sendChat()">
      <button onclick="sendChat()"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
  <button class="chat-btn" onclick="toggleChat()" title="Chat with us">
    <i class="fas fa-comments"></i>
  </button>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <i class="fas fa-bell"></i>
  <div class="toast-content"><h5 id="toastTitle"></h5><p id="toastMsg"></p></div>
</div>

<script>
  // --- APPLICATION MODAL ---
  let currentStep = 1;
  const totalSteps = 6;

  function openApply(service) {
    const titles = {
      subscription: 'Subscription Cancellation',
      debt: 'Debt Consolidation',
      insurance: 'Insurance Optimization',
      banking: 'Banking Fee Audit',
      telecom: 'Telecom Review',
      credit: 'Credit Report Review'
    };
    document.getElementById('modalTitle').textContent = 'Apply: ' + (titles[service] || 'Service Application');
    // Pre-check relevant service
    document.querySelectorAll('#serviceCheckboxes input[type=checkbox]').forEach(cb => {
      if (cb.value === service) cb.checked = true;
    });
    document.getElementById('applyModal').classList.add('active');
    currentStep = 1;
    updateSteps();
    initSignature();
    return false;
  }

  function closeApply() {
    document.getElementById('applyModal').classList.remove('active');
    document.getElementById('successScreen').style.display = 'none';
    document.getElementById('formNav').style.display = 'flex';
    currentStep = 1;
    updateSteps();
  }

  function updateSteps() {
    document.querySelectorAll('.form-step').forEach((s, i) => {
      s.classList.toggle('active', i + 1 === currentStep);
    });
    const dots = document.getElementById('stepDots');
    dots.innerHTML = '';
    for (let i = 1; i <= totalSteps; i++) {
      const d = document.createElement('div');
      d.className = 'step-dot' + (i === currentStep ? ' active' : i < currentStep ? ' done' : '');
      dots.appendChild(d);
    }
    document.getElementById('stepLabel').textContent = `Step ${currentStep} of ${totalSteps}`;
    document.getElementById('prevBtn').style.display = currentStep > 1 ? 'block' : 'none';
    document.getElementById('nextBtn').textContent = currentStep === totalSteps ? 'Submit Application' : 'Continue →';
    if (currentStep === totalSteps) buildReview();
  }

  function buildReview() {
    const s = document.getElementById('reviewSummary');
    const v = id => document.getElementById(id)?.value || '—';
    s.innerHTML = `
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 24px">
        <div><span style="color:var(--white);font-weight:600">Name:</span> ${v('f_first')} ${v('f_last')}</div>
        <div><span style="color:var(--white);font-weight:600">ID:</span> ${v('f_id')}</div>
        <div><span style="color:var(--white);font-weight:600">Email:</span> ${v('f_email')}</div>
        <div><span style="color:var(--white);font-weight:600">Phone:</span> ${v('f_phone')}</div>
        <div><span style="color:var(--white);font-weight:600">Income:</span> R${Number(v('f_income')).toLocaleString()}/mo</div>
        <div><span style="color:var(--white);font-weight:600">Package:</span> ${v('f_package').split('—')[0]}</div>
        <div><span style="color:var(--white);font-weight:600">Bank:</span> ${v('f_bank')}</div>
        <div><span style="color:var(--white);font-weight:600">Account:</span> ****${v('f_accnum').slice(-4)}</div>
      </div>`;
  }

  function nextStep() {
    if (currentStep < totalSteps) {
      currentStep++;
      updateSteps();
    } else {
      submitApplication();
    }
  }

  function prevStep() {
    if (currentStep > 1) { currentStep--; updateSteps(); }
  }

  function submitApplication() {
    const ref = 'CP-' + Math.floor(100000 + Math.random() * 900000);
    document.getElementById('refNumber').textContent = 'REF: ' + ref;
    document.querySelectorAll('.form-step').forEach(s => s.style.display = 'none');
    document.getElementById('stepDots').style.display = 'none';
    document.getElementById('formNav').style.display = 'none';
    document.getElementById('successScreen').style.display = 'block';
    showToast('Application Submitted!', 'Reference: ' + ref);
    saveApplicationToStorage(ref);
  }

  function saveApplicationToStorage(ref) {
    const apps = JSON.parse(localStorage.getItem('cp_applications') || '[]');
    apps.push({
      ref, date: new Date().toISOString(),
      name: (document.getElementById('f_first')?.value || '') + ' ' + (document.getElementById('f_last')?.value || ''),
      email: document.getElementById('f_email')?.value || '',
      phone: document.getElementById('f_phone')?.value || '',
      income: document.getElementById('f_income')?.value || '',
      bank: document.getElementById('f_bank')?.value || '',
      package: document.getElementById('f_package')?.value || '',
      status: 'New',
      notes: document.getElementById('f_notes')?.value || ''
    });
    localStorage.setItem('cp_applications', JSON.stringify(apps));
  }

  // --- FILE UPLOADS ---
  document.getElementById('upBankStmt').addEventListener('change', function() {
    showFiles(this.files, 'upBankStmtList');
  });
  document.getElementById('upID').addEventListener('change', function() {
    showFiles(this.files, 'upIDList');
  });
  document.getElementById('upIncome').addEventListener('change', function() {
    showFiles(this.files, 'upIncomeList');
  });
  function showFiles(files, listId) {
    const list = document.getElementById(listId);
    list.innerHTML = Array.from(files).map(f =>
      `<div style="display:flex;gap:8px;align-items:center;margin-top:4px"><i class="fas fa-check-circle" style="color:var(--success)"></i>${f.name} (${(f.size/1024).toFixed(0)}KB)</div>`
    ).join('');
  }

  // --- SIGNATURE ---
  let sigCtx, sigDrawing = false;
  function initSignature() {
    setTimeout(() => {
      const canvas = document.getElementById('sigCanvas');
      if (!canvas) return;
      canvas.width = canvas.offsetWidth || 540;
      sigCtx = canvas.getContext('2d');
      sigCtx.strokeStyle = '#C9A84C';
      sigCtx.lineWidth = 2;
      sigCtx.lineCap = 'round';
      canvas.addEventListener('mousedown', e => { sigDrawing = true; sigCtx.beginPath(); sigCtx.moveTo(e.offsetX, e.offsetY); });
      canvas.addEventListener('mousemove', e => { if (!sigDrawing) return; sigCtx.lineTo(e.offsetX, e.offsetY); sigCtx.stroke(); });
      canvas.addEventListener('mouseup', () => sigDrawing = false);
      canvas.addEventListener('touchstart', e => {
        sigDrawing = true; const r = canvas.getBoundingClientRect(); const t = e.touches[0];
        sigCtx.beginPath(); sigCtx.moveTo(t.clientX - r.left, t.clientY - r.top); e.preventDefault();
      }, {passive:false});
      canvas.addEventListener('touchmove', e => {
        if (!sigDrawing) return; const r = canvas.getBoundingClientRect(); const t = e.touches[0];
        sigCtx.lineTo(t.clientX - r.left, t.clientY - r.top); sigCtx.stroke(); e.preventDefault();
      }, {passive:false});
      canvas.addEventListener('touchend', () => sigDrawing = false);
    }, 200);
  }
  function clearSig() {
    const c = document.getElementById('sigCanvas');
    if (sigCtx) sigCtx.clearRect(0, 0, c.width, c.height);
  }
  function downloadPOA() {
    const text = document.getElementById('poaText').innerText;
    const name = document.getElementById('f_first')?.value + ' ' + document.getElementById('f_last')?.value;
    const blob = new Blob([`POWER OF ATTORNEY\n\nClient: ${name}\nDate: ${new Date().toLocaleDateString('en-ZA')}\n\n${text}`], {type:'text/plain'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href = url; a.download = `ClearPath_POA_${name.replace(/ /g,'_')}.txt`; a.click();
    showToast('Download Started', 'POA document downloaded');
  }

  // --- CHAT ---
  function toggleChat() {
    document.getElementById('chatWindow').classList.toggle('open');
  }
  function sendChat() {
    const input = document.getElementById('chatInput');
    const msg = input.value.trim();
    if (!msg) return;
    const msgs = document.getElementById('chatMsgs');
    msgs.innerHTML += `<div class="chat-msg client">${msg}</div>`;
    input.value = '';
    setTimeout(() => {
      msgs.innerHTML += `<div class="chat-msg agent">Thanks for your message! A consultant will respond shortly. For urgent queries, WhatsApp us on 081 234 5678. 🌟</div>`;
      msgs.scrollTop = msgs.scrollHeight;
    }, 800);
    msgs.scrollTop = msgs.scrollHeight;
    saveChatMsg(msg);
  }
  function saveChatMsg(msg) {
    const chats = JSON.parse(localStorage.getItem('cp_chats') || '[]');
    chats.push({ msg, time: new Date().toISOString(), from: 'client' });
    localStorage.setItem('cp_chats', JSON.stringify(chats));
  }

  // --- TOAST ---
  function showToast(title, msg) {
    document.getElementById('toastTitle').textContent = title;
    document.getElementById('toastMsg').textContent = msg;
    const toast = document.getElementById('toast');
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 4000);
  }

  // --- CLOSE MODAL ON OVERLAY CLICK ---
  document.getElementById('applyModal').addEventListener('click', function(e) {
    if (e.target === this) closeApply();
  });

  // --- ANIMATE BARS ON LOAD ---
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.bar-fill').forEach(b => { const w = b.style.width; b.style.width = '0'; setTimeout(() => b.style.width = w, 100); });
    }, 500);
  });
</script>
</body>
</html>
