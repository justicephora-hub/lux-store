function clearAudit() {
  document.getElementById('debtRows').innerHTML = `<div style="display:grid;grid-template-columns:1fr 80px 80px 90px 90px 36px;gap:8px;margin-bottom:8px;font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;padding:0 4px"><span>Creditor Name</span><span>Balance</span><span>Rate %</span><span>Monthly</span><span>Remaining</span><span></span></div>`;
  debtRowCount = 0; initDebtAudit(); calcAudit();
}
function calcAudit() {
  let totalDebt = 0, totalMonthly = 0;
  for (let i = 1; i <= debtRowCount; i++) {
    const b = parseFloat(document.getElementById('d_balance_'+i)?.value || 0);
    const m = parseFloat(document.getElementById('d_monthly_'+i)?.value || 0);
    totalDebt += b; totalMonthly += m;
  }
  const net = parseFloat(document.getElementById('audit_net')?.value || 0);
  const living = parseFloat(document.getElementById('audit_living')?.value || 0);
  const rate = parseFloat(document.getElementById('consol_rate')?.value || 18) / 100 / 12;
  const term = parseInt(document.getElementById('consol_term')?.value || 60);
  const consolMonthly = totalDebt > 0 && rate > 0 ? (totalDebt * rate * Math.pow(1+rate,term)) / (Math.pow(1+rate,term)-1) : 0;
  const saving = totalMonthly - consolMonthly;
  const available = net - living - totalMonthly;
  const dti = net > 0 ? (totalMonthly / net * 100).toFixed(1) : 0;
  const affordPct = Math.min(100, Math.max(0, 100 - dti));

  const fmt = n => 'R' + Math.abs(n).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');
  document.getElementById('sum_total_debt').textContent = fmt(totalDebt);
  document.getElementById('sum_monthly').textContent = fmt(totalMonthly);
  document.getElementById('sum_net_income').textContent = fmt(net);
  document.getElementById('sum_living').textContent = fmt(living);
  document.getElementById('sum_dti').textContent = dti + '%';
  document.getElementById('sum_available').textContent = (available >= 0 ? '' : '-') + fmt(available);
  document.getElementById('sum_available').style.color = available >= 0 ? 'var(--success)' : 'var(--danger)';
  document.getElementById('sum_saving').textContent = (saving > 0 ? '' : '-') + fmt(saving);
  document.getElementById('sum_consol_amount').textContent = fmt(totalDebt);
  document.getElementById('afford_fill').style.width = affordPct + '%';
  document.getElementById('afford_fill').style.background = affordPct > 60 ? 'var(--success)' : affordPct > 30 ? 'var(--warning)' : 'var(--danger)';
  document.getElementById('afford_label').textContent = affordPct > 60 ? '✓ Good affordability' : affordPct > 30 ? '⚠ Moderate — review carefully' : '✗ High debt burden';
}
