  const tb = document.getElementById('appTableBody');
  if (!tb) return;
  tb.innerHTML = filtered.map(a => `
    <tr onclick="viewApp('${a.ref}')">
      <td style="color:var(--gold);font-weight:600;font-size:12px">${a.ref||'—'}</td>
      <td><strong>${a.name||'—'}</strong></td>
      <td style="color:var(--text-muted);font-size:13px">${a.email||'—'}</td>
      <td style="font-size:13px">${a.phone||'—'}</td>
      <td style="font-size:12px">${(a.package||'—').split('—')[0].trim()}</td>
      <td style="font-size:12px">${a.bank||'—'}</td>
