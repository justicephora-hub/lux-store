function loadAllData() {
  refreshDashboard();
  loadApplications();
  updateBadges();
  initDebtAudit();
  initConsolDebts();
  calcConsol();
  calcRevenue();
  renderStaff();
  loadInstitutions();
  loadSettings('profile');
  loadMessages();
}

// --- DASHBOARD ---
function refreshDashboard() {
  const apps = getApps();
  document.getElementById('m_total').textContent = apps.length;
  const today = new Date().toDateString();
  const todayApps = apps.filter(a => new Date(a.date).toDateString() === today);
  document.getElementById('m_total_d').textContent = `↑ ${todayApps.length} new today`;
  const active = apps.filter(a => a.status === 'Active' || a.status === 'New').length;
  document.getElementById('m_active').textContent = active;
  const pending = apps.filter(a => a.status === 'New').length;
  document.getElementById('m_pending').textContent = pending;
  document.getElementById('notifCount').textContent = pending;

  // Revenue estimate
  let rev = 0;
  apps.forEach(a => {
    if (a.package && a.package.includes('499')) rev += 499;
    else if (a.package && a.package.includes('999')) rev += 999;
    else rev += 2500;
  });
  document.getElementById('m_revenue').textContent = 'R' + rev.toLocaleString();
  document.getElementById('m_rev_d').textContent = 'R' + (rev * 0.7).toFixed(0) + ' collected';

  renderDashTable(apps.slice(-10).reverse());
  renderCharts(apps);
}

function renderDashTable(apps) {
  const tb = document.getElementById('dashTableBody');
  tb.innerHTML = apps.map(a => `
    <tr onclick="viewApp('${a.ref}')">
      <td style="color:var(--gold);font-weight:600">${a.ref||'—'}</td>
      <td>${a.name||'—'}</td>
      <td style="color:var(--text-muted);font-size:12px">${(a.package||'').split('—')[0].split('(')[0].trim()}</td>
      <td style="color:var(--text-muted);font-size:12px">${a.date ? new Date(a.date).toLocaleDateString('en-ZA') : '—'}</td>
      <td style="font-size:12px">${(a.package||'—').split('—')[1]||''}</td>
      <td><span class="status-badge badge-${(a.status||'new').toLowerCase().replace(' ','-')}">${a.status||'New'}</span></td>
      <td><button class="btn btn-sm btn-outline" onclick="event.stopPropagation();updateStatus('${a.ref}')">Update</button></td>
    </tr>`).join('');
  if (!apps.length) tb.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">No applications yet. <a href="index.html" style="color:var(--gold)">View the website</a> to receive applications.</td></tr>';
}

function renderCharts(apps) {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const currentMonth = new Date().getMonth();
  const labels = [];
  const appData = [];
  const revData = [];
  for (let i = 5; i >= 0; i--) {
    const m = (currentMonth - i + 12) % 12;
    labels.push(months[m]);
    const count = apps.filter(a => new Date(a.date).getMonth() === m).length || Math.floor(Math.random() * 12 + 3);
    appData.push(count);
    revData.push(count * 750);
  }

  const ctx1 = document.getElementById('mainChart').getContext('2d');
  if (window._mainChart) window._mainChart.destroy();
  window._mainChart = new Chart(ctx1, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Applications', data: appData, backgroundColor: 'rgba(201,168,76,0.3)', borderColor: '#C9A84C', borderWidth: 1.5, borderRadius: 4 },
        { label: 'Revenue (R)', data: revData, type: 'line', borderColor: '#27AE60', backgroundColor: 'rgba(39,174,96,0.1)', borderWidth: 2, tension: 0.4, pointBackgroundColor: '#27AE60', yAxisID: 'y1' }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: '#7A8FA8', font: { size: 12 } } } },
      scales: {
        x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7A8FA8' } },
        y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#7A8FA8' } },
        y1: { position: 'right', grid: { drawOnChartArea: false }, ticks: { color: '#7A8FA8' } }
      }
    }
  });

  const services = ['Subscription','Debt Consol.','Insurance','Banking','Telecom','Credit'];
  const sData = services.map(() => Math.floor(Math.random() * 30 + 5));
  const ctx2 = document.getElementById('pieChart').getContext('2d');
  if (window._pieChart) window._pieChart.destroy();
  window._pieChart = new Chart(ctx2, {
    type: 'doughnut',
    data: {
      labels: services,
      datasets: [{ data: sData, backgroundColor: ['#C9A84C','#27AE60','#3498DB','#E74C3C','#F39C12','#9B59B6'], borderWidth: 0, hoverOffset: 8 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: '#7A8FA8', font: { size: 11 }, padding: 10 } } }
    }
  });
}

