let _revChart;
function calcRevenue() {
  const v = id => parseFloat(document.getElementById(id)?.value || 0);
  const basic = v('rev_basic') * v('rev_basic_price');
  const full = v('rev_full') * v('rev_full_price');
  const consol = v('rev_consol') * v('rev_consol_fee');
  const perf = v('rev_savings') * v('rev_perf_pct') / 100;
  const costs = v('rev_costs');
  const gross = basic + full + consol + perf;
  const net = gross - costs;
  const fmt = n => 'R' + Math.abs(n).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');
  document.getElementById('rv_basic').textContent = fmt(basic);
  document.getElementById('rv_full').textContent = fmt(full);
  document.getElementById('rv_consol').textContent = fmt(consol);
  document.getElementById('rv_perf').textContent = fmt(perf);
  document.getElementById('rv_gross').textContent = fmt(gross);
  document.getElementById('rv_costs_out').textContent = fmt(costs);
  document.getElementById('rv_net').textContent = fmt(net);
  document.getElementById('rv_net').style.color = net >= 0 ? 'var(--gold)' : 'var(--danger)';
  const ctx = document.getElementById('revenueChart');
  if (!ctx) return;
  if (_revChart) _revChart.destroy();
  _revChart = new Chart(ctx.getContext('2d'), {
    type: 'bar',
    data: {
      labels: ['Basic','Full Opt.','Consol.','Performance','Costs','Net'],
      datasets: [{ data: [basic,full,consol,perf,costs,net],
        backgroundColor: ['#C9A84C','#27AE60','#3498DB','#F39C12','rgba(231,76,60,0.6)','rgba(201,168,76,0.9)'],
        borderRadius: 4 }]
    },
    options: { responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}},
      scales:{x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7A8FA8',font:{size:10}}},y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7A8FA8',callback:v=>'R'+v.toLocaleString()}}} }
  });
}

