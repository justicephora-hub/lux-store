      <div style="background:rgba(201,168,76,0.06);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:16px"><p style="font-size:13px;color:var(--text-muted)"><i class="fas fa-info-circle" style="color:var(--gold);margin-right:8px"></i>For DebiCheck integration (NAEDO/AEDO), use Netcash or BankServ Africa's DebiCheck API. Register at netcash.co.za for credentials.</p></div>
      <button class="btn btn-gold" onclick="showToast('Saved','Payment settings saved')">Save & Connect</button>`,
    notifications: `<h3>Notification Settings</h3>
      <div style="display:flex;flex-direction:column;gap:14px">
        ${['New application received','Application status changed','Payment received','New client message','Daily report summary'].map(n =>
          `<label style="display:flex;justify-content:space-between;align-items:center;cursor:pointer"><span style="font-size:14px">${n}</span><input type="checkbox" checked style="accent-color:var(--gold);width:18px;height:18px"></label>`
        ).join('')}
      </div>
      <button class="btn btn-gold" style="margin-top:20px" onclick="showToast('Saved','Notification preferences saved')">Save</button>`
  };
  const el = document.getElementById('settingsContent');
  if (el) el.innerHTML = content[tab] || content.profile;
}
function showSettingsTab(tab, el) {
  document.querySelectorAll('.settings-menu-item').forEach(i => i.classList.remove('active'));
  if (el) el.classList.add('active');
  loadSettings(tab);
}
async function changePassword() {
  const np = document.getElementById('newPass')?.value;
  const cp = document.getElementById('confirmPass')?.value;
  if (!np || np !== cp) { showToast('Error','Passwords do not match'); return; }
  if (np.length < 8) { showToast('Error','Password must be at least 8 characters'); return; }
  // Update both hash store and legacy plain store
  const newHash = await sha256(np);
  const stored = JSON.parse(localStorage.getItem('cp_admin_credentials') || '{}');
  stored.passwordHash = newHash;
  stored.updatedAt = new Date().toISOString();
  localStorage.setItem('cp_admin_credentials', JSON.stringify(stored));
  localStorage.setItem('cp_admin_pw', np); // legacy compatibility
  showToast('Password Updated', 'Your new password is active');
}

// --- TOAST ---
function showToast(title, msg) {
  document.getElementById('aToastTitle').textContent = title;
  document.getElementById('aToastMsg').textContent = msg;
  const t = document.getElementById('adminToast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3500);
}

// Check if already logged in session
window.onload = function() {
  const loggedIn = sessionStorage.getItem('cp_logged_in');
  if (loggedIn) {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('sidebar').style.display = 'flex';
    document.getElementById('mainContent').style.display = 'flex';
    loadAllData();
  }
};
</script>
