        <button class="btn btn-sm btn-danger" onclick="event.stopPropagation();deleteApp('${a.ref}')"><i class="fas fa-trash"></i></button>
      </td>
    </tr>`).join('');
  if (!filtered.length) tb.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-muted)">No applications found.</td></tr>';
}

function filterDashTable() {
  const s = document.getElementById('dashSearch').value.toLowerCase();
