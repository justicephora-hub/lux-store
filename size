    <input type="number" placeholder="21.5" style="flex:1;max-width:70px" id="d_rate_${debtRowCount}" oninput="calcAudit()">
    <input type="number" placeholder="1200" style="flex:1" id="d_monthly_${debtRowCount}" oninput="calcAudit()">
    <input type="number" placeholder="48" style="flex:1;max-width:80px" id="d_months_${debtRowCount}">
    <button class="del-btn" onclick="document.getElementById('dr_${debtRowCount}').remove();calcAudit()"><i class="fas fa-times"></i></button>`;
  document.getElementById('debtRows').appendChild(row);
